#include <DMD32.h>
#include "fonts/SystemFont5x7.h"

#define DISPLAYS_ACROSS 1
#define DISPLAYS_DOWN 2
DMD dmd(DISPLAYS_ACROSS, DISPLAYS_DOWN);

hw_timer_t* timer = NULL;
String mesin  = "C502";
String target = "300";
String aktual = "300";
String persen = "100%";
void updateDisplay() {

dmd.clearScreen(true);
dmd.selectFont(SystemFont5x7);

dmd.drawString(0, 0,  mesin.c_str(),  mesin.length(),  GRAPHICS_NORMAL);
dmd.drawString(0, 8,  target.c_str(), target.length(), GRAPHICS_NORMAL);
dmd.drawString(0,16,  aktual.c_str(), aktual.length(), GRAPHICS_NORMAL);
dmd.drawString(0,24,  persen.c_str(), persen.length(), GRAPHICS_NORMAL);

}
void IRAM_ATTR triggerScan() {
  dmd.scanDisplayBySPI();
}

void setup() {
  Serial.begin(115200);

uint8_t cpuClock = ESP.getCpuFreqMHz();

timer = timerBegin(0, cpuClock, true);
timerAttachInterrupt(timer, &triggerScan, true);
timerAlarmWrite(timer, 100, true);
timerAlarmEnable(timer);
updateDisplay(); 
}

void loop() {
}
