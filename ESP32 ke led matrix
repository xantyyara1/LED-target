#include <WiFi.h>
#include <PubSubClient.h>
#include <DMD32.h>
#include "fonts/SystemFont5x7.h"

#define DISPLAYS_ACROSS 1
#define DISPLAYS_DOWN 2
#define PIN_COUNTER 27

const char* WIFI_SSID = "Repeater_PPIC";
const char* WIFI_PASSWORD = "9876543210repeat";
const char* MQTT_SERVER = "192.168.31.13";
const uint16_t MQTT_PORT = 1883;
const char* MACHINE_ID = "0502";

DMD dmd(DISPLAYS_ACROSS, DISPLAYS_DOWN);
WiFiClient espClient;
PubSubClient mqtt(espClient);
hw_timer_t *timer = NULL;

void IRAM_ATTR triggerScan()
{
    dmd.scanDisplayBySPI();
}

String mesin = "C502";
String target = "300";
String aktual = "0";
String persen = "0%";

uint32_t counter = 0;

String topicCounter;
String topicTarget;
String topicReset;
String topicStatus;
String topicMesin;

bool lastState = HIGH;
uint32_t lastValidPulse = 0;
const uint32_t LOCK_TIME_US = 50000; //filter 50ms

void updateDisplay()
{
    dmd.clearScreen(true);
    dmd.drawString(0, 0, mesin.c_str(), mesin.length(), GRAPHICS_NORMAL);
    dmd.drawString(0, 8, target.c_str(), target.length(), GRAPHICS_NORMAL);
    dmd.drawString(0,16, aktual.c_str(), aktual.length(), GRAPHICS_NORMAL);
    dmd.drawString(0,24, persen.c_str(), persen.length(), GRAPHICS_NORMAL);
}

void hitungPersen()
{
    int t = target.toInt();
    int a = aktual.toInt();

    if (t <= 0)
    {
        persen = "0%";
        return;
    }

    persen = String((a * 100) / t) + "%";
}

void setTarget(int value)
{
    target = String(value);
    hitungPersen();
    updateDisplay();
}

void setAktual(int value)
{
    aktual = String(value);
    hitungPersen();
    updateDisplay();
}

void setupWiFi()
{
    Serial.println();
    Serial.println("Connecting WiFi...");

    WiFi.mode(WIFI_STA);
    WiFi.begin(WIFI_SSID, WIFI_PASSWORD);

    while (WiFi.status() != WL_CONNECTED)
    {
        delay(500);
        Serial.print(".");
    }

    Serial.println();
    Serial.println("WiFi Connected");
    Serial.print("IP Address : ");
    Serial.println(WiFi.localIP());
}
void setupMQTT()
{
    mqtt.setServer(MQTT_SERVER, MQTT_PORT);
}
void reconnectMQTT()
{
    while (!mqtt.connected())
    {
        Serial.print("Connecting MQTT... ");

        String clientId = "ESP32-" + String(MACHINE_ID);

        if (mqtt.connect(clientId.c_str()))
        {
            Serial.println("Connected");
        }
        else
        {
            Serial.print("Failed, rc=");
            Serial.print(mqtt.state());
            Serial.println(" Retry 5s");

            delay(5000);
        }
    }
}
void setup()
{
    Serial.begin(115200);
    topicCounter = "cnc/" + String(MACHINE_ID) + "/counter";
    topicTarget  = "cnc/" + String(MACHINE_ID) + "/target";
    topicReset   = "cnc/" + String(MACHINE_ID) + "/reset";
    topicStatus  = "cnc/" + String(MACHINE_ID) + "/status";
    topicMesin   = "cnc/" + String(MACHINE_ID) + "/mesin";

    uint8_t cpuClock = ESP.getCpuFreqMHz();

    timer = timerBegin(0, cpuClock, true);
    timerAttachInterrupt(timer, &triggerScan, true);
    timerAlarmWrite(timer, 100, true);
    timerAlarmEnable(timer);

    pinMode(PIN_COUNTER, INPUT_PULLUP);

    dmd.selectFont(SystemFont5x7);

    setTarget(100);
    setAktual(0);

    lastState = digitalRead(PIN_COUNTER);
    setupWiFi();
    setupMQTT();
}

void loop()
{
    if (!mqtt.connected())
    {
        reconnectMQTT();
    }

    mqtt.loop();
    bool state = digitalRead(PIN_COUNTER);
    Serial.print("lastState = ");
    Serial.print(lastState);
    Serial.print("  state = ");
    Serial.println(state);

    // Hitung hanya saat relay OFF
    if (lastState == LOW && state == HIGH)
    {
        uint32_t now = micros();

        if ((now - lastValidPulse) >= LOCK_TIME_US)
        {
            lastValidPulse = now;

            counter++;

            Serial.print("Counter = ");
            Serial.println(counter);

            setAktual(counter);
        }
    }

    lastState = state;
}
